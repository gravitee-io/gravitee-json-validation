{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "endpoint": {
            "type": "object",
            "oneOf": [
                {
                    "title": "Fixed",
                    "properties": {
                        "mode": { "const": "FIXED" },
                        "value": { "type": "integer", "default": 1 }
                    },
                    "required": ["mode", "value"],
                    "additionalProperties": false
                },
                {
                    "title": "Free",
                    "properties": {
                        "mode": { "type": "string" },
                        "label": { "type": "string", "default": "free" }
                    },
                    "required": ["mode", "label"],
                    "additionalProperties": false
                }
            ]
        }
    }
}
